# Local PostgreSQL. Replace the password outside disposable local development.
POSTGRES_USER=pe_agent
POSTGRES_PASSWORD=replace-with-a-local-password
POSTGRES_DB=pe_agent_db
TEST_POSTGRES_DB=pe_agent_test
POSTGRES_PORT=5432

# Backend. The test database must contain "test" and must differ from DATABASE_URL.
ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://pe_agent:replace-with-a-local-password@localhost:5432/pe_agent_db
TEST_DATABASE_URL=postgresql+psycopg://pe_agent:replace-with-a-local-password@localhost:5432/pe_agent_test
CORS_ORIGINS=http://localhost:3000
CRM_INTEGRATION_MODE=direct
DOCUMENT_INTEGRATION_MODE=direct
MAX_UPLOAD_BYTES=10000000

# Embeddings. Hashing is the offline default. Set the external cache explicitly
# only when opting into the pinned MiniLM semantic provider.
EMBEDDING_PROVIDER=hashing
EMBEDDING_MODEL_NAME=local-hashing-384-v1
SEMANTIC_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_REVISION=1110a243fdf4706b3f48f1d95db1a4f5529b4d41
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32
VECTOR_MIN_SIMILARITY=0.15
VECTOR_MAX_TOP_K=50
RAG_MAX_CONTEXT_WORDS=1200
# HF_MODEL_CACHE_DIR=/absolute/path/outside/this/repository

# News and trigger intelligence. The checked-in source registry enables only a
# local mock fixture. Network sources remain disabled until both the registry
# and exact HTTPS host allowlist are explicitly configured server-side.
NEWS_SOURCE_CONFIG=./data/news_sources.json
NEWS_FIXTURE_ROOT=./data/seed
SEED_DATA_DIR=./data/seed
NEWS_ALLOWED_HOSTS=
NEWS_SYNC_API_ENABLED=true
NEWS_MAX_ITEMS=100
NEWS_MAX_RESPONSE_BYTES=2000000
NEWS_HTTP_TIMEOUT_SECONDS=10
NEWS_HTTP_CONNECT_TIMEOUT_SECONDS=5
NEWS_MAX_REDIRECTS=3
NEWS_MAX_RETRIES=2
NEWS_HOST_MIN_INTERVAL_SECONDS=0.5
NEWS_COMPANY_MATCH_THRESHOLD=0.8
NEWS_EVENT_MERGE_DAYS=7
NEWS_EVENT_MERGE_SIMILARITY=0.7
TRIGGER_EXTRACTION_MODE=rules
TRIGGER_EXTRACTION_VERSION=m3-rules-v1
# TRIGGER_LLM_ENDPOINT=https://allowlisted-provider.example/v1/chat/completions
# TRIGGER_LLM_MODEL=
# TRIGGER_LLM_API_KEY_ENV=OPENAI_API_KEY
# TRIGGER_LLM_ALLOWED_HOSTS=allowlisted-provider.example

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional providers. Never commit real credentials.
# OPENAI_API_KEY=
# FIRECRAWL_API_KEY=
